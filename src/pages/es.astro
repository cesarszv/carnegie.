---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import MemoryCard from '../components/MemoryCard.astro';

const entry = await getEntry('landing', 'es');
if (!entry) {
  throw new Error('Spanish landing content spec not found');
}
const { data } = entry;
---

<Layout
  title={data.title}
  description={data.description}
  lang="es"
>
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-copy">
      <p class="eyebrow">{data.hero.eyebrow}</p>
      <h1 id="hero-title">{data.hero.title}</h1>
      <p class="lede">
        {data.hero.lede}
      </p>
      {data.hero.actions && (
        <div class="hero-actions" aria-label="Primary actions">
          <a class="button" href={data.hero.actions.primary.href}>{data.hero.actions.primary.text}</a>
          <a class="text-link" href={data.hero.actions.secondary.href}>{data.hero.actions.secondary.text}</a>
        </div>
      )}
    </div>

    <MemoryCard lang="es" />
  </section>

  <section class="idea" id="idea" aria-labelledby="idea-title">
    <p class="section-kicker">{data.idea.kicker}</p>
    <h2 id="idea-title">{data.idea.title}</h2>
    <div class="idea-grid">
      {data.idea.items.map((item) => (
        <article>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="principles" id="principles" aria-labelledby="principles-title">
    <div>
      <p class="section-kicker">{data.principles.kicker}</p>
      <h2 id="principles-title">{data.principles.title}</h2>
    </div>
    <ul>
      {data.principles.items.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <section class="closing" aria-labelledby="closing-title">
    <h2 id="closing-title">{data.closing.title}</h2>
    <p>
      {data.closing.text}
    </p>
    <a class="button" href={data.closing.button.href} rel={data.closing.button.href.startsWith('http') ? "noopener" : undefined}>
      {data.closing.button.href.includes('github.com') && (
        <svg aria-hidden="true" viewBox="0 0 16 16" focusable="false" style="width: 1.05rem; height: 1.05rem; flex: none; margin-right: 0.55rem;">
          <path
            fill="currentColor"
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
          />
        </svg>
      )}
      {data.closing.button.text}
    </a>
  </section>
</Layout>
