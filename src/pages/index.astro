---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import MemoryCard from '../components/MemoryCard.astro';

const entry = await getEntry('landing', 'en');
if (!entry) {
  throw new Error('English landing content spec not found');
}
const { data } = entry;
---

<Layout
  title={data.title}
  description={data.description}
  lang="en"
>
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-copy">
      <p class="eyebrow">{data.hero.eyebrow}</p>
      <h1 id="hero-title">{data.hero.title}</h1>
      <p class="lede">
        {data.hero.lede}
      </p>
      {data.hero.actions && (
        <div class="hero-actions" aria-label="Primary actions">
          <a class="button" href={data.hero.actions.primary.href}>{data.hero.actions.primary.text}</a>
          <a class="text-link" href={data.hero.actions.secondary.href}>{data.hero.actions.secondary.text}</a>
        </div>
      )}
    </div>

    <MemoryCard lang="en" />
  </section>

  <section class="idea" id="idea" aria-labelledby="idea-title">
    <p class="section-kicker">{data.idea.kicker}</p>
    <h2 id="idea-title">{data.idea.title}</h2>
    <div class="idea-grid">
      {data.idea.items.map((item) => (
        <article>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="principles" id="principles" aria-labelledby="principles-title">
    <div>
      <p class="section-kicker">{data.principles.kicker}</p>
      <h2 id="principles-title">{data.principles.title}</h2>
    </div>
    <ul>
      {data.principles.items.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <section class="closing" aria-labelledby="closing-title">
    <h2 id="closing-title">{data.closing.title}</h2>
    <p>
      {data.closing.text}
    </p>
    <a class="button" href={data.closing.button.href}>{data.closing.button.text}</a>
  </section>
</Layout>
